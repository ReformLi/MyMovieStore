<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/playerRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:keepScreenOn="true"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- 播放器视图：填满整个屏幕 -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/playerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:resize_mode="fit"
        app:show_timeout="4000"
        app:show_buffering="when_playing"
        app:show_subtitle_button="false"
        app:show_vr_button="false"
        app:surface_type="texture_view"
        app:use_controller="true"
        app:controller_layout_id="@layout/exo_player_control_view" />

    <!-- 弹幕容器：屏幕顶部 25% 高度，覆盖在播放器之上 -->
    <FrameLayout
        android:id="@+id/danmakuContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintHeight_percent="0.25"
        android:clipChildren="true"
        android:clipToPadding="false" />

    <!-- 顶部控制栏 -->
    <LinearLayout
        android:id="@+id/topControls"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_player_top_gradient"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingTop="16dp"
        android:paddingEnd="14dp"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_player_round_button"
            android:contentDescription="返回"
            android:padding="10dp"
            android:src="@drawable/ic_player_back" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvPlayerTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="#FFFFFFFF"
                android:textSize="17sp"
                android:textStyle="bold"
                tools:text="红了樱桃绿了芭蕉" />

            <TextView
                android:id="@+id/tvPlayerEpisode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="#CCFFFFFF"
                android:textSize="13sp"
                android:visibility="gone"
                tools:text="第2集"
                tools:visibility="visible" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnRotate"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_player_round_button"
            android:contentDescription="切换屏幕方向"
            android:padding="10dp"
            android:src="@drawable/ic_player_rotate" />
    </LinearLayout>

    <!-- 屏幕锁定按钮（左侧中间） -->
    <ImageButton
        android:id="@+id/btnLock"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="12dp"
        android:background="@drawable/bg_player_round_button"
        android:contentDescription="锁定屏幕"
        android:padding="12dp"
        android:src="@drawable/ic_player_unlock"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 锁定状态下的只读进度条（屏幕底部） -->
    <LinearLayout
        android:id="@+id/lockedProgressBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_player_top_gradient"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent">

        <TextView
            android:id="@+id/tvLockedPosition"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:includeFontPadding="false"
            android:paddingEnd="8dp"
            android:textColor="#FFFFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            tools:text="00:00" />

        <ProgressBar
            android:id="@+id/progressBarLocked"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="0dp"
            android:layout_height="4dp"
            android:layout_weight="1"
            android:progressDrawable="@drawable/bg_download_progress"
            android:max="100"
            android:progress="0" />

        <TextView
            android:id="@+id/tvLockedDuration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:includeFontPadding="false"
            android:paddingStart="8dp"
            android:textColor="#FFFFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            tools:text="00:00" />
    </LinearLayout>

    <!-- 手势提示 -->
    <TextView
        android:id="@+id/tvGestureTip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/bg_player_gesture_tip"
        android:gravity="center"
        android:minWidth="120dp"
        android:paddingStart="18dp"
        android:paddingTop="12dp"
        android:paddingEnd="18dp"
        android:paddingBottom="12dp"
        android:textColor="#FFFFFFFF"
        android:textSize="15sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        tools:text="音量 60%"
        tools:visibility="visible" />

</androidx.constraintlayout.widget.ConstraintLayout>
